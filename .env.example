# YouTube Channel Analyzer - Environment Variables
# Copy this file to .env and fill in real values

# Anthropic API key for Claude knowledge file generation
LLM_API_KEY=your_anthropic_api_key_here

# Flask secret key for session cookies (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=generate_a_random_secret_key_here

# Shared site password for team access
SITE_PASSWORD=choose_a_team_password_here
